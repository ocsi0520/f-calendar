{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug - need to import describe,it,expect from vitest",
      // import { describe, it, expect } from 'vitest';
      "type": "node",
      "request": "launch",
      "autoAttachChildProcesses": true,
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect-brk", "./node_modules/vitest/vitest.mjs", "run", "${file}"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach to ng test (Vitest)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "timeout": 10000,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
